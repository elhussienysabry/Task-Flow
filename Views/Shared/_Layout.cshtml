<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/collaboration.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TaskManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow" style="padding: 0.5rem 0;">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index" style="font-size: 1.1rem;">
                    <i class="fas fa-tasks"></i> TaskFlow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 mb-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Dashboard" asp-action="Index" style="font-size: 0.95rem;">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Projects" asp-action="Index" style="font-size: 0.95rem;">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Activities" asp-action="Index" style="font-size: 0.95rem;">Activity</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-link theme-toggle-btn p-1" id="themeToggleBtn" onclick="toggleTheme()" style="font-size: 1rem;">
                            <i class="fas fa-moon"></i>
                        </button>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container mt-2">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-5 pt-3 pb-3" style="background-color: #f8f9fa; font-size: 0.85rem;">
        <div class="container">
            <div class="row small">
                <div class="col-md-4 mb-2">
                    <h6 class="fw-bold mb-1"><i class="fas fa-tasks text-primary"></i> TaskFlow</h6>
                    <p class="mb-0 text-muted">Task management & collaboration platform</p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="fw-bold mb-1"><i class="fas fa-link"></i> Links</h6>
                    <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="text-muted text-decoration-none d-block">Dashboard</a>
                    <a asp-area="" asp-controller="Projects" asp-action="Index" class="text-muted text-decoration-none d-block">Projects</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none d-block">Privacy</a>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="fw-bold mb-1"><i class="fas fa-info"></i> Info</h6>
                    <p class="mb-0 text-muted">&copy; 2026 TaskFlow v1.0</p>
                    <p class="mb-0 text-muted"><i class="fas fa-heart text-danger"></i> Built for teams</p>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
