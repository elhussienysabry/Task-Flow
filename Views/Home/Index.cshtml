@{
    ViewData["Title"] = "Home";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="container">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-home"></i> Welcome back, @User.Identity?.Name!
            </h1>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="m-0">
                            <i class="fas fa-rocket"></i> Quick Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <a asp-controller="Projects" asp-action="Create" class="btn btn-lg btn-primary w-100">
                                    <i class="fas fa-folder-plus"></i> Create New Project
                                </a>
                            </div>
                            <div class="col-md-6">
                                <a asp-controller="Projects" asp-action="Index" class="btn btn-lg btn-info w-100">
                                    <i class="fas fa-list"></i> View My Projects
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow">
                    <div class="card-header bg-info text-white">
                        <h5 class="m-0">
                            <i class="fas fa-info-circle"></i> Getting Started
                        </h5>
                    </div>
                    <div class="card-body">
                        <h6>Welcome to TaskFlow!</h6>
                        <p>TaskFlow is your personal project and task management system. Here's how to get started:</p>
                        <ol>
                            <li><strong>Create a Project:</strong> Organize your work by creating projects for different initiatives.</li>
                            <li><strong>Add Tasks:</strong> Break down your projects into actionable tasks with priorities and deadlines.</li>
                            <li><strong>Assign & Track:</strong> Assign tasks to yourself or team members and track progress.</li>
                            <li><strong>Collaborate:</strong> Add comments on tasks to keep everyone in the loop.</li>
                            <li><strong>Monitor Dashboard:</strong> Use the dashboard to see your workload at a glance.</li>
                        </ol>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="m-0">
                            <i class="fas fa-tasks"></i> Task Statuses
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-warning text-dark p-2" style="width: 100px;">To Do</span>
                            <p class="ms-2 mb-0">Tasks waiting to be started</p>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-info text-white p-2" style="width: 100px;">In Progress</span>
                            <p class="ms-2 mb-0">Tasks currently being worked on</p>
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="badge bg-success text-white p-2" style="width: 100px;">Done</span>
                            <p class="ms-2 mb-0">Completed tasks</p>
                        </div>
                    </div>
                </div>

                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="m-0">
                            <i class="fas fa-flag"></i> Priority Levels
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <span class="badge bg-info">Low</span>
                            <p class="small text-muted d-inline-block ms-2">Can be done when time permits</p>
                        </div>
                        <div class="mb-2">
                            <span class="badge bg-warning text-dark">Medium</span>
                            <p class="small text-muted d-inline-block ms-2">Should be done soon</p>
                        </div>
                        <div>
                            <span class="badge bg-danger">High</span>
                            <p class="small text-muted d-inline-block ms-2">Urgent, needs immediate attention</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="min-vh-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="text-center text-white">
            <div class="mb-4">
                <i class="fas fa-tasks" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-4 mb-3">TaskFlow</h1>
            <p class="lead mb-5">Your Personal Project & Task Management System</p>
            
            <div class="row mb-5 justify-content-center">
                <div class="col-md-8">
                    <p class="mb-4">
                        Organize your work, track your progress, and collaborate with ease.
                        TaskFlow makes project management simple and intuitive.
                    </p>
                </div>
            </div>

            <div class="row justify-content-center g-3">
                <div class="col-md-4 col-sm-6 mb-3">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-lg w-100">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                </div>
                <div class="col-md-4 col-sm-6 mb-3">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg w-100">
                        <i class="fas fa-user-plus"></i> Register
                    </a>
                </div>
            </div>

            <div class="mt-5 pt-5">
                <div class="row justify-content-center text-center">
                    <div class="col-md-3">
                        <i class="fas fa-project-diagram fa-2x mb-2"></i>
                        <h6>Organize</h6>
                        <p class="small">Create projects to organize your work</p>
                    </div>
                    <div class="col-md-3">
                        <i class="fas fa-tasks fa-2x mb-2"></i>
                        <h6>Manage</h6>
                        <p class="small">Track tasks and deadlines</p>
                    </div>
                    <div class="col-md-3">
                        <i class="fas fa-comments fa-2x mb-2"></i>
                        <h6>Collaborate</h6>
                        <p class="small">Add comments and discuss</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
