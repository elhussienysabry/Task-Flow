@model IEnumerable<TaskManagementSystem.ViewModels.TaskViewModel>

@{
    ViewData["Title"] = "Tasks";
    var project = ViewBag.Project as TaskManagementSystem.Models.Project;
}

<div class="container">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-tasks"></i> Tasks - @project?.Name
            </h1>
            <small class="text-muted">@project?.Description</small>
        </div>
        <a asp-action="Create" asp-route-projectId="@project?.Id" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus"></i> Create New Task
        </a>
    </div>

    <!-- Filter Form -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" id="filterForm">
                <input type="hidden" name="projectId" value="@project?.Id" />
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label"><i class="fas fa-search"></i> Search by Title</label>
                            <input type="text" name="SearchString" class="form-control" placeholder="Enter task title..." value="@ViewData["currentFilter"]" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="form-label"><i class="fas fa-list"></i> Status</label>
                            <select name="status" class="form-control" asp-items="Html.GetEnumSelectList<TaskManagementSystem.Models.TaskStatus>()">
                                <option value="">All Status</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="form-label"><i class="fas fa-flag"></i> Priority</label>
                            <select name="priority" class="form-control" asp-items="Html.GetEnumSelectList<TaskManagementSystem.Models.TaskPriority>()">
                                <option value="">All Priority</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-group w-100">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-filter"></i> Filter
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                var statusBadgeClass = item.Status switch
                {
                    TaskManagementSystem.Models.TaskStatus.ToDo => "bg-warning",
                    TaskManagementSystem.Models.TaskStatus.InProgress => "bg-info",
                    TaskManagementSystem.Models.TaskStatus.Done => "bg-success",
                    _ => "bg-secondary"
                };
                
                var priorityClass = item.Priority switch
                {
                    TaskManagementSystem.Models.TaskPriority.Low => "text-info",
                    TaskManagementSystem.Models.TaskPriority.Medium => "text-warning",
                    TaskManagementSystem.Models.TaskPriority.High => "text-danger",
                    _ => "text-secondary"
                };

                var isOverdue = item.Deadline.HasValue && item.Deadline.Value < DateTime.Now && item.Status != TaskManagementSystem.Models.TaskStatus.Done;
                
                <div class="col-lg-6 mb-4">
                    <div class="card shadow h-100 @(isOverdue ? "border-danger border-2" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title">@item.Title</h5>
                                <span class="badge @statusBadgeClass text-white">@item.Status</span>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="card-text text-muted small">@item.Description</p>
                            }
                            
                            <div class="row mt-3 mb-3">
                                <div class="col-6">
                                    <small class="text-muted d-block"><i class="fas fa-flag @priorityClass"></i> Priority: <strong>@item.Priority</strong></small>
                                </div>
                                <div class="col-6 text-right">
                                    <small class="text-muted d-block">
                                        @if (item.Deadline.HasValue)
                                        {
                                            <i class="fas fa-calendar"></i> 
                                            if (isOverdue)
                                            {
                                                <span class="text-danger"><strong>OVERDUE</strong></span>
                                            }
                                            else
                                            {
                                                <span>@item.Deadline.Value.ToString("MMM dd, yyyy")</span>
                                            }
                                        }
                                    </small>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(item.AssignedUserName))
                            {
                                <small class="d-block text-muted mb-2">
                                    <i class="fas fa-user-circle"></i> Assigned to: <strong>@item.AssignedUserName</strong>
                                </small>
                            }
                        </div>
                        <div class="card-footer bg-light">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-danger delete-task" data-id="@item.Id">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-none" id="delete-form-@item.Id"></form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center p-5" role="alert">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <h4>No Tasks Yet</h4>
            <p>Create your first task to get started!</p>
            <a asp-action="Create" asp-route-projectId="@project?.Id" class="btn btn-primary mt-3">
                <i class="fas fa-plus"></i> Create Task
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.delete-task').on('click', function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#delete-form-' + id).submit();
                    }
                })
            });
        });
    </script>
}
