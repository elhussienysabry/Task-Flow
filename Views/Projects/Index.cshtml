@model IEnumerable<TaskManagementSystem.ViewModels.ProjectViewModel>

@{
    ViewData["Title"] = "Projects";
}

<div class="container">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-project-diagram mr-2"></i>My Projects
        </h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus mr-2"></i>Create New Project
        </a>
    </div>

    <!-- Search Form -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-10">
                        <input type="text" name="SearchString" class="form-control" placeholder="Search projects by name..." value="@ViewData["currentFilter"]" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card shadow h-100">
                        <div class="card-body">
                            <h5 class="card-title text-primary">
                                <i class="fas fa-folder-open"></i> @item.Name
                            </h5>
                            <p class="card-text text-gray-600">@item.Description</p>
                            
                            <div class="row mt-3">
                                <div class="col-6">
                                    <small class="text-muted">Tasks Completed</small>
                                    <div class="h6">@item.CompletedTaskCount / @item.TaskCount</div>
                                </div>
                                <div class="col-6 text-right">
                                    <small class="text-muted">Progress</small>
                                    <div class="h6">@item.CompletionPercentage.ToString("0.0")%</div>
                                </div>
                            </div>
                            
                            <div class="progress mt-2" style="height: 24px;">
                                <div class="progress-bar bg-success" role="progressbar" 
                                     style="width: @item.CompletionPercentage.ToString("0.00")%;" 
                                     aria-valuenow="@item.CompletionPercentage" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    @item.CompletionPercentage.ToString("0.00")%
                                </div>
                            </div>
                            
                            <small class="d-block text-muted mt-3">Created: @item.CreatedDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="card-footer bg-light">
                            <a asp-controller="Tasks" asp-action="Index" asp-route-projectId="@item.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-list-ul"></i> View Tasks
                            </a>
                            <a asp-action="ManageCollaborators" asp-route-id="@item.Id" class="btn btn-sm btn-success">
                                <i class="fas fa-users"></i> Team
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-danger delete-project" data-id="@item.Id">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-none" id="delete-form-@item.Id"></form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center p-5" role="alert">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <h4>No Projects Yet</h4>
            <p>Create your first project to get started!</p>
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="fas fa-plus"></i> Create Project
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.delete-project').on('click', function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#delete-form-' + id).submit();
                    }
                })
            });
        });
    </script>
}
