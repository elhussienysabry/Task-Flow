@{
    ViewData["Title"] = "Manage Collaborators";
}

<div class="container mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0">
                <i class="fas fa-users-cog"></i> Manage Team
            </h1>
            <small class="text-muted">Project: <strong>@ViewBag.ProjectName</strong></small>
        </div>
        <a href="@Url.Action("Index", "Projects")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to Projects
        </a>
    </div>

    <div class="row">
        <!-- Add Collaborator Panel -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="fas fa-user-plus"></i> Add Team Member</h6>
                </div>
                <div class="card-body">
                    <form id="addCollaboratorForm">
                        <div class="mb-3">
                            <label for="email" class="form-label"><i class="fas fa-envelope"></i> Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="user@example.com" required>
                            <small class="form-text text-muted">Enter the email of the user you want to add</small>
                        </div>

                        <div class="mb-3">
                            <label for="role" class="form-label"><i class="fas fa-shield-alt"></i> Role</label>
                            <select class="form-select" id="role" name="role">
                                <option value="Contributor" selected>Contributor - Can create and edit tasks</option>
                                <option value="Editor">Editor - Can edit project details</option>
                                <option value="Viewer">Viewer - View only access</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="note" class="form-label"><i class="fas fa-sticky-note"></i> Note (Optional)</label>
                            <textarea class="form-control" id="note" name="note" rows="2" placeholder="Add a note for this collaborator..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-plus"></i> Add Collaborator
                        </button>
                    </form>
                </div>
            </div>

            <!-- Team Tips -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="fas fa-lightbulb"></i> Collaboration Tips</h6>
                </div>
                <div class="card-body small">
                    <ul class="mb-0">
                        <li><strong>Contributor:</strong> Best for team members doing tasks</li>
                        <li><strong>Editor:</strong> For project managers</li>
                        <li><strong>Viewer:</strong> For stakeholders who only need updates</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Collaborators List -->
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0 font-weight-bold"><i class="fas fa-people-carry"></i> Team Members</h6>
                </div>
                <div class="card-body" id="collaboratorsList">
                    <div class="text-center py-5">
                        <i class="fas fa-spinner fa-spin fa-2x text-primary mb-3"></i>
                        <p class="text-muted">Loading team members...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const projectId = @ViewBag.ProjectId;

        document.getElementById('addCollaboratorForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const role = document.getElementById('role').value;
            
            try {
                const response = await fetch(`/Projects/AddCollaborator?projectId=${projectId}&email=${email}&role=${role}`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: result.message
                    });
                    document.getElementById('addCollaboratorForm').reset();
                    loadCollaborators();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: result.message
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while adding the collaborator'
                });
            }
        });

        async function loadCollaborators() {
            // This would load the list of current collaborators
            // For now showing placeholder
        }

        // Load collaborators on page load
        document.addEventListener('DOMContentLoaded', loadCollaborators);

        function removeCollaborator(userId) {
            Swal.fire({
                title: 'Remove Collaborator?',
                text: 'Are you sure you want to remove this team member?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Remove'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch(`/Projects/RemoveCollaborator?projectId=${projectId}&userId=${userId}`, {
                            method: 'GET',
                            headers: {
                                'Accept': 'application/json'
                            }
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            Swal.fire('Removed!', result.message, 'success');
                            loadCollaborators();
                        } else {
                            Swal.fire('Error', result.message, 'error');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                    }
                }
            });
        }
    </script>
}
