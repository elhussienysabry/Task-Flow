@model System.Collections.Generic.List<TaskManagementSystem.ViewModels.ActivityViewModel>

@{
    ViewData["Title"] = "Activity Log";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between">
                <h1 class="h3 mb-0"><i class="fas fa-history"></i> Activity Log</h1>
                <div class="btn-group" role="group">
                    @if (Model.Any())
                    {
                        <form method="post" action="@Url.Action("ClearLog", "Activities")" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Are you sure you want to clear all your activity logs? This action cannot be undone.');">
                                <i class="fas fa-trash"></i> Clear Log
                            </button>
                        </form>
                    }
                    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-primary">
                        <i class="fas fa-chart-line"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label for="actionFilter" class="form-label"><i class="fas fa-filter"></i> Activity Type</label>
                            <select id="actionFilter" class="form-control" onchange="document.getElementById('activityForm').submit();">
                                <option value="">All Activities</option>
                                <option value="Created">Created</option>
                                <option value="Updated">Updated</option>
                                <option value="Deleted">Deleted</option>
                                <option value="Commented">Commented</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="dateSort" class="form-label"><i class="fas fa-sort"></i> Sort</label>
                            <select id="dateSort" class="form-control" onchange="document.getElementById('activityForm').submit();">
                                <option value="">Newest First</option>
                                <option value="asc">Oldest First</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="reset" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-sync"></i> Reset
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 120px;"><i class="fas fa-info-circle"></i> Type</th>
                                        <th><i class="fas fa-align-left"></i> Description</th>
                                        <th><i class="fas fa-folder"></i> Project</th>
                                        <th><i class="fas fa-tasks"></i> Task</th>
                                        <th><i class="fas fa-user"></i> User</th>
                                        <th style="width: 180px;"><i class="fas fa-calendar"></i> Date & Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var activity in Model.OrderByDescending(a => a.CreatedAt))
                                    {
                                        <tr>
                                            <td>
                                                @switch (activity.ActionType)
                                                {
                                                    case "Created":
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-plus"></i> Created
                                                        </span>
                                                        break;
                                                    case "Updated":
                                                        <span class="badge bg-info">
                                                            <i class="fas fa-edit"></i> Updated
                                                        </span>
                                                        break;
                                                    case "Deleted":
                                                        <span class="badge bg-danger">
                                                            <i class="fas fa-trash"></i> Deleted
                                                        </span>
                                                        break;
                                                    case "Commented":
                                                        <span class="badge bg-warning">
                                                            <i class="fas fa-comment"></i> Commented
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@activity.ActionType</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <small>@activity.Description</small>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(activity.ProjectName))
                                                {
                                                    <small>@activity.ProjectName</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(activity.TaskTitle))
                                                {
                                                    <small>@activity.TaskTitle</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td>
                                                <small>
                                                    <i class="fas fa-user"></i>
                                                    @activity.UserName
                                                </small>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @activity.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <p class="text-muted mb-0">
                                <i class="fas fa-inbox fa-3x opacity-25 d-block mb-3"></i>
                                No activities yet
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>